# Payment Gateway Environment Variables

# Webhook Configuration
WEBHOOK_SECRET=webhook_secret_dev_123

# Other Payment Gateways (Optional)
# 2C2P Configuration
# C2P_MERCHANT_ID=your_merchant_id
# C2P_SECRET_KEY=your_secret_key

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Application Settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_LINE_LOGIN=false
NODE_ENV=development

# LINE Login (set in Supabase provider configuration)
# LINE Login channel should be linked to the same Official Account/provider used by the Messaging API token below.
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret

# LINE Messaging API (for push notifications)
# Use one of these variables (same token value)
LINE_MESSAGING_API_TOKEN=your-line-messaging-api-channel-access-token
# LINE_CHANNEL_ACCESS_TOKEN=your-line-messaging-api-channel-access-token
# Optional secret for secure LINE action links (fallback: LINE_CHANNEL_SECRET)
LINE_ACTION_SECRET=your-long-random-line-action-secret

# Custom LINE OAuth callback (if LINE provider is not available in Supabase)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
LINE_REDIRECT_URI=http://localhost:3000/api/auth/line/callback
LINE_FRONTEND_SUCCESS_URL=http://localhost:3000/auth/success
LINE_FRONTEND_ERROR_URL=http://localhost:3000/login
LINE_PASSWORD_SECRET=your-very-strong-random-secret

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=XYL Studio