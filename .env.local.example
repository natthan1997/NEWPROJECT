# Supabase Configuration
# Get these values from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Email Configuration (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME="Xylem Landscape"

# Stripe Payment Gateway
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Application Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
NEXT_PUBLIC_ENABLE_LINE_LOGIN=false

# LINE Login (configure in Supabase Auth -> Providers -> LINE)
# Callback URL example: http://localhost:3000/login
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret

# LINE Messaging API (for push notifications)
# Use one of these variables (same token value)
LINE_MESSAGING_API_TOKEN=your-line-messaging-api-channel-access-token
# LINE_CHANNEL_ACCESS_TOKEN=your-line-messaging-api-channel-access-token
# Optional secret for secure LINE action links (fallback: LINE_CHANNEL_SECRET)
LINE_ACTION_SECRET=your-long-random-line-action-secret

# Custom LINE OAuth callback (when not using Supabase LINE provider)
SUPABASE_URL=your-project-url.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
LINE_REDIRECT_URI=http://localhost:3000/api/auth/line/callback
LINE_FRONTEND_SUCCESS_URL=http://localhost:3000/auth/success
LINE_FRONTEND_ERROR_URL=http://localhost:3000/login
LINE_PASSWORD_SECRET=your-very-strong-random-secret

# Security
WEBHOOK_SECRET=your-webhook-secret-for-verification

# Monitoring (Optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
